    "\n",
    "print(f'\\nKlassfördelning Train \\n{y_train.value_counts(normalize=True)}')\n",
    "print(f'\\nKlassfördelning Test \\n{y_test.value_counts(normalize=True)}')"
   ]
  },
  {
   "cell_type": "markdown",
